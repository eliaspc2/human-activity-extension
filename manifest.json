{
  "manifest_version": 3,
  "name": "Human Activity Extension",
  "description": "Injects a floating controller into the active tab to simulate reading-like activity with scrolling, cursor movement, and neutral clicks.",
  "version": "1.0.3",
  "minimum_chrome_version": "114",
  "update_url": "https://raw.githubusercontent.com/eliaspc2/human-activity-extension/main/updates.xml",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Inject Human Activity controller"
  }
}
